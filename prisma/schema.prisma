// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url is intentionally omitted here - it's provided via prisma.config.ts
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  applications  Application[]
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum AppStatus {
  Bookmarked
  Applied
  Interview
  Offer
  Rejected
}

model Application {
  id              String     @id @default(cuid())
  companyName     String
  jobTitle        String
  jobUrl          String
  status          AppStatus  @default(Bookmarked)
  dateApplied     DateTime   @default(now())
  contactName     String?
  contactLinkedIn String?
  notes           String?
  followUpDate    DateTime?
  salaryRange     String?
  matchScore      Int
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("Application")
}